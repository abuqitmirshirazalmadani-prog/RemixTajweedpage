rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper: is user signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: is authenticated user the designated verified administrator
    function isAdmin() {
      return isSignedIn() 
        && request.auth.token.email == 'abuqitmirshirazalmadani@gmail.com' 
        && request.auth.token.email_verified == true;
    }

    // Helper: ID check to prevent ID poisoning / wallet exhaustion attacks
    function isValidId(id) {
      return id is string 
        && id.size() >= 1 
        && id.size() <= 128 
        && id.matches('^[a-zA-Z0-9_-]+$');
    }

    // Helper: Validate Blog Post fields
    function isValidBlog(data) {
      return data.keys().hasAll([
        'id', 'slug', 'category', 'titleNL', 'titleEN', 
        'subtitleNL', 'subtitleEN', 'author', 'readTime', 
        'date', 'imageUrl', 'quoteNL', 'quoteEN', 
        'contentNL', 'contentEN', 'createdAt'
      ])
        && data.id is string && data.id.size() <= 128
        && data.slug is string && data.slug.size() <= 500
        && data.category is string && data.category.size() <= 500
        && data.titleNL is string && data.titleNL.size() <= 1000
        && data.titleEN is string && data.titleEN.size() <= 1000
        && data.subtitleNL is string && data.subtitleNL.size() <= 5000
        && data.subtitleEN is string && data.subtitleEN.size() <= 5000
        && data.author is map
        && data.readTime is string && data.readTime.size() <= 500
        && data.date is string && data.date.size() <= 500
        && data.imageUrl is string && data.imageUrl.size() <= 5000
        && data.quoteNL is string && data.quoteNL.size() <= 5000
        && data.quoteEN is string && data.quoteEN.size() <= 5000
        && data.contentNL is list && data.contentNL.size() <= 1000
        && data.contentEN is list && data.contentEN.size() <= 1000;
    }

    // 2. Collection Rules for "blogs"
    match /blogs/{blogId} {
      // Public articles are visible to all visitors
      allow read, list: if true;

      // Only the verified admin can create blog documents
      allow create: if isAdmin() 
        && isValidId(blogId) 
        && isValidBlog(request.resource.data)
        && request.resource.data.createdAt is timestamp;

      // Only the verified admin can update block contents
      allow update: if isAdmin() 
        && isValidId(blogId)
        && isValidBlog(request.resource.data)
        && request.resource.data.id == resource.data.id
        && request.resource.data.createdAt == resource.data.createdAt;

      // Only the verified admin can delete articles
      allow delete: if isAdmin() && isValidId(blogId);
    }

    // 3. Collection Rules for "bookings"
    match /bookings/{bookingId} {
      // Public visitors can submit bookings/lead registrations
      allow create: if isValidId(bookingId)
        && request.resource.data.fullName is string
        && request.resource.data.email is string;

      // Only the verified administrator can read, list, update, or delete registrations
      allow read, list, update, delete: if isAdmin();
    }
  }
}
